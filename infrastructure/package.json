{
  "name": "b2b-infrastructure",
  "version": "1.0.0",
  "description": "AWS CDK Infrastructure for B2B Application",
  "bin": {
    "infrastructure": "bin/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --all",
    "deploy:network": "cdk deploy B2BNetworkingStack",
    "deploy:database": "cdk deploy B2BDatabaseStack",
    "deploy:compute": "cdk deploy B2BComputeStack",
    "deploy:lambda": "cdk deploy B2BLambdaStack",
    "destroy": "cdk destroy --all",
    "diff": "cdk diff",
    "bootstrap": "cdk bootstrap"
  },
  "keywords": ["cdk", "aws", "infrastructure"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3",
    "aws-cdk": "^2.117.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.117.0",
    "constructs": "^10.3.0"
  }
}
